# Base Image for Agentic Data Pipeline Ingestor
# This image contains all heavy ML/AI dependencies
# Build and push to registry: docker build -f Dockerfile.base -t agentic-pipeline-base:latest .

FROM python:3.11-slim AS builder

# Set build environment
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install heavy dependencies first (these change less frequently)
RUN pip install --upgrade pip && \
    pip install \
    # Core ML/AI libraries (heavy, slow to install)
    torch --index-url https://download.pytorch.org/whl/cpu \
    sentence-transformers \
    transformers \
    numpy scipy scikit-learn \
    # Document processing (heavy)
    docling \
    # Graph databases
    neo4j>=5.15.0 \
    "cognee[postgres,neo4j]>=0.5.3" \
    # Multi-hop reasoning
    hipporag>=0.1.0 \
    # Azure AI
    azure-ai-vision-imageanalysis

# Runtime stage
FROM python:3.11-slim AS runtime

# Set runtime environment
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1 \
    PIP_NO_CACHE_DIR=1 \
    PATH="/opt/venv/bin:$PATH"

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    libmagic1 \
    poppler-utils \
    tesseract-ocr \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv

# Verify installations
RUN python -c "import torch; import sentence_transformers; import cognee; import hipporag; print('Base image dependencies verified')"

# Labels
LABEL maintainer="Agentic Pipeline Team" \
      description="Base image with ML/AI dependencies for Agentic Data Pipeline" \
      version="1.0.0"
